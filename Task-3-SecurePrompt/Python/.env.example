# ── Database ──────────────────────────────────────────────────────────────
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://your_db_user:your_db_password@localhost:5432/your_db_name

# ── Flask ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_random_64_char_hex_string

FLASK_DEBUG=false
